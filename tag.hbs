{{#*inline "body"}}
<main class="site-main">

    {{#with tag}}
    <section class="tag">

        <div class="gh-canvas">

            <h1 class="tag-name">{{name}}</h1>

            {{#if description}}
                <div class="tag-description">{{description}}</div>
            {{/if}}

            {{#if feature_image}}
                <div class="tag-media u-placeholder horizontal kg-width-wide">
                    <img class="u-object-fit" srcset="{{> partials/srcset}}" src="{{img_url feature_image size="l"}}" alt="{{name}}">
                </div>
            {{/if}}

        </div>

    </section>
    {{/with}}

    <div class="post-feed gh-feed gh-canvas">
        {{#foreach posts}}
            {{> partials/loop}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>
{{/inline}}
{{> default}}